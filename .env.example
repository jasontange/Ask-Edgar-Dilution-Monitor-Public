# Ask Edgar API Keys (get from https://askedgar.io - requires Enterprise plan)
# The dilution key is specifically for the dilution-rating endpoint
# The data key covers float, news, and dilution-data endpoints
ASKEDGAR_DILUTION_API_KEY=your_dilution_api_key_here
ASKEDGAR_DATA_API_KEY=your_data_api_key_here

# Massive.com API Key (get from https://massive.com - for live stock prices)
# Optional: if not set, the "In Play Dilution" section won't show price-based filtering
MASSIVE_API_KEY=your_massive_api_key_here
